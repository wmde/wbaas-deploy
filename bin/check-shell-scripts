#!/usr/bin/env bash

# runs shfmt and shellcheck for each file in this repo that is considered a shell script

# based on https://github.com/bewuethr/shellcheck-action/blob/main/runshellcheck
# more information: https://github.com/koalaman/shellcheck/wiki/Recursiveness

find . \
    -type d -name '.git' -prune \
    -or \
    -type f -path '*/.terraform/*' -prune \
    -or \
    -type f \( \
    -exec sh -c 'file --brief "$1" \
            | grep --quiet --extended-regexp \
              "((POSIX|Korn|Bourne-Again) shell|/usr/bin/env k?sh) script"' _ {} \; \
    -or \
    -name '*.sh' -or -name '*.bash' -or -name '*.ksh' \
    \) \
    -exec docker run --rm -t -v "$(pwd):/mnt" -w /mnt -u "$(id -u):$(id -g)" mvdan/shfmt:v3 \
    --diff \
    --indent 4 \
    --binary-next-line \
    --case-indent \
    {} + \
    -exec docker run --rm -t -v "$(pwd):/mnt" koalaman/shellcheck:v0.11.0 {} +
